# Copy to .env and edit as needed. All variables are OPTIONAL in v1 —
# the tool runs with zero configuration and no paid APIs.

# Optional CoinGecko Demo API key (raises rate limits). Free to omit.
COINGECKO_API_KEY=

# Optional DefiLlama Pro API key. If set, the tool pulls DIA's OFFICIAL oracle
# TVS (+ history -> real growth trend) and DIA fees, replacing the manual
# figure in config/oracle_tvs.yaml. Omit to run free. Keep this secret — .env
# is gitignored; never commit it.
DEFILLAMA_API_KEY=

# Override the DIA CoinGecko coin id (default: dia-data).
DIA_COINGECKO_ID=dia-data

# Where to store the SQLite database (default: dia_alpha_monitor.db).
DIA_DB_PATH=dia_alpha_monitor.db

# Config directory holding the YAML files (default: config).
DIA_CONFIG_DIR=config

# CSV export directory (default: exports).
DIA_EXPORT_DIR=exports
